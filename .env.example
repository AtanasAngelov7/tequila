# Tequila v2 — Environment Variables
# Copy to .env and fill in your values.

# Server binding (default: 127.0.0.1:8000)
TEQUILA_HOST=127.0.0.1
TEQUILA_PORT=8000

# Gateway authentication token (leave blank to disable in local dev)
TEQUILA_GATEWAY_TOKEN=

# Enable debug mode (enables hot-reload, verbose logging, etc.)
TEQUILA_DEBUG=false

# Optional: override data directory (default: ./data/ in dev, %LOCALAPPDATA%/Tequila/ when frozen)
# TEQUILA_DATA_DIR=./data
